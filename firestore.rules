rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isAdminEmail() { return request.auth.token.email == 'emperorsrujal@gmail.com'; }
    function isMasterAdmin() { return uid() == 'zgf9IVlnH1Mh6s2eA8g9worURoQ2'; }
    function userRole() { 
      return exists(/databases/$(database)/documents/users/$(uid())) 
        ? get(/databases/$(database)/documents/users/$(uid())).data.role 
        : 'none'; 
    }
    function isSuperAdmin() { 
      return isMasterAdmin() || isAdminEmail() || (isAuth() && userRole() in ['super_admin', 'super-admin', 'manager']); 
    }
    function isManager() { return isSuperAdmin() || (isAuth() && userRole() == 'manager'); }
    function isManagerOrLandlord() { return isManager() || (isAuth() && userRole() == 'landlord'); }

    // Users — read own, managers can read all, others can read managers/landlords
    match /users/{userId} {
      allow read: if isAuth() && (
        uid() == userId || 
        isManager() || 
        resource.data.role in ['manager', 'landlord'] ||
        request.auth.token.email == 'emperorsrujal@gmail.com'
      );
      
      // On creation, a user CANNOT set themselves as a 'manager' or 'landlord'. They must be a 'tenant' or 'owner'.
      // Only the Super Admin bypasses this.
      allow create: if isAuth() && uid() == userId && (
        request.resource.data.role in ['tenant', 'owner'] || isAdminEmail()
      );
      
      // On update, users can edit their profile BUT CANNOT CHANGE THEIR OWN ROLE natively.
      allow update: if isAuth() && (
        (uid() == userId && request.resource.data.role == resource.data.role) || isAdminEmail()
      );
    }

    // Properties & Buildings
    match /properties/{propId} {
      allow read, list: if true; // Public access for property selection in anonymous reports
      allow write: if isAuth() && isManagerOrLandlord();
    }
    match /properties {
      allow read, list: if true;
    }

    // Tenants — managers/landlords full access, tenants read their own
    match /tenants/{tenantId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow create, update, delete: if isAuth() && isManagerOrLandlord();
    }

    // Payments — managers/landlords full access, tenants read their own
    match /payments/{payId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow create, update: if isAuth() && isManagerOrLandlord();
      allow create: if isAuth() && userRole() == 'tenant';
    }

    // Maintenance Requests
    match /maintenance/{reqId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow create: if true; // Public access for anonymous reporting
      allow update: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow delete: if isAuth() && isManager();
    }
    match /maintenance {
      allow create: if true;
      allow read, list: if isAuth() && isManagerOrLandlord();
    }

    // Documents — managers full access, tenants read their own
    match /documents/{docId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.tenantId == null || resource.data.userId == uid());
      allow create: if isAuth();
      allow update: if isAuth() && (isManagerOrLandlord() || resource.data.uploadedById == uid());
      allow delete: if isAuth() && isManagerOrLandlord();
    }

    // Announcements — managers can write, everyone can read
    match /announcements/{annId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Threads / Messages
    match /threads/{threadId} {
      allow read: if isAuth() && uid() in resource.data.participants;
      allow create: if isAuth() && uid() in request.resource.data.participants;
      allow update: if isAuth() && uid() in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
      }
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update: if isAuth() && resource.data.userId == uid();
      allow create: if isAuth();
    }

    // Keys
    match /keys/{keyId} {
      allow read, write: if isAuth() && isManagerOrLandlord();
    }

    // Packages
    match /packages/{pkgId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.tenantId == uid());
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Deposits / LMR
    match /deposits/{depId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.tenantId == uid());
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Evictions
    match /evictions/{evId} {
      allow read, write: if isAuth() && isManagerOrLandlord();
    }

    // HOA: Bylaw Violations
    match /violations/{vId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.ownerId == uid());
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // HOA: Reserve Fund
    match /reserve_fund/{rfId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // HOA: Reserve Fund Projects
    match /reserve_projects/{rpId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // HOA: Board Meetings
    match /boardMeetings/{mId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();

      match /votes/{vId} {
        allow read: if isAuth();
        allow create, update: if isAuth();
      }
    }

    // HOA: Special Assessments
    match /assessments/{aId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Vendors
    match /vendors/{vId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Registry (Pets & Vehicles)
    match /registry/{rId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow update, delete: if isAuth() && isManagerOrLandlord();
    }

    // Amenity Bookings
    match /bookings/{bId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow delete: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow update: if isAuth() && isManagerOrLandlord();
    }

    // Visitor Management
    match /visitors/{vId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.residentId == uid());
      allow create: if isAuth() && request.resource.data.residentId == uid();
      allow update, delete: if isAuth() && (isManagerOrLandlord() || resource.data.residentId == uid());
    }
  }
}
