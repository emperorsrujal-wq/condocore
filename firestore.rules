rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function userRole() { return get(/databases/$(database)/documents/users/$(uid())).data.role; }
    function isManager() { return userRole() == 'manager'; }
    function isManagerOrLandlord() { return userRole() in ['manager', 'landlord']; }

    // Users — read own, managers can read all
    match /users/{userId} {
      allow read: if isAuth() && (uid() == userId || isManager() || request.auth.token.email == 'emperorsrujal@gmail.com');
      
      // On creation, a user CANNOT set themselves as a 'manager' or 'landlord'. They must be a 'tenant' or 'owner'.
      // Only the Super Admin bypasses this.
      allow create: if isAuth() && uid() == userId && (
        request.resource.data.role in ['tenant', 'owner'] || 
        request.auth.token.email == 'emperorsrujal@gmail.com'
      );
      
      // On update, users can edit their profile BUT CANNOT CHANGE THEIR OWN ROLE natively.
      allow update: if isAuth() && (
        (uid() == userId && request.resource.data.role == resource.data.role) || 
        request.auth.token.email == 'emperorsrujal@gmail.com'
      );
    }

    // Properties — managers can do everything, others can read
    match /properties/{propId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Tenants — managers/landlords full access, tenants read their own
    match /tenants/{tenantId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow create, update, delete: if isAuth() && isManagerOrLandlord();
    }

    // Payments — managers/landlords full access, tenants read their own
    match /payments/{payId} {
      allow read: if isAuth() && (isManagerOrLandlord() || get(/databases/$(database)/documents/tenants/$(resource.data.tenantId)).data.userId == uid());
      allow create, update: if isAuth() && isManagerOrLandlord();
      // Tenants can create own payment records
      allow create: if isAuth() && userRole() == 'tenant';
    }

    // Maintenance — managers full access, tenants read/create their own
    match /maintenance/{reqId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow create: if isAuth();
      allow update: if isAuth() && (isManagerOrLandlord() || resource.data.userId == uid());
      allow delete: if isAuth() && isManager();
    }

    // Documents — managers full access, tenants read their own
    match /documents/{docId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.tenantId == null || resource.data.userId == uid());
      allow create: if isAuth();
      allow update: if isAuth() && (isManagerOrLandlord() || resource.data.uploadedById == uid());
      allow delete: if isAuth() && isManagerOrLandlord();
    }

    // Announcements — managers can write, everyone can read
    match /announcements/{annId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Threads / Messages
    match /threads/{threadId} {
      allow read: if isAuth() && uid() in resource.data.participants;
      allow create: if isAuth() && uid() in request.resource.data.participants;
      allow update: if isAuth() && uid() in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
      }
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update: if isAuth() && resource.data.userId == uid();
      allow create: if isAuth();
    }

    // Keys
    match /keys/{keyId} {
      allow read, write: if isAuth() && isManagerOrLandlord();
    }

    // Packages
    match /packages/{pkgId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.tenantId == uid());
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Deposits / LMR
    match /deposits/{depId} {
      allow read: if isAuth() && (isManagerOrLandlord() || resource.data.tenantId == uid());
      allow write: if isAuth() && isManagerOrLandlord();
    }

    // Evictions
    match /evictions/{evId} {
      allow read, write: if isAuth() && isManagerOrLandlord();
    }

    // HOA: Bylaw Violations
    match /violations/{vId} {
      allow read, write: if isAuth() && isManagerOrLandlord();
    }

    // HOA: Reserve Fund
    match /reserve_fund/{rfId} {
      allow read, write: if isAuth() && isManagerOrLandlord();
    }
  }
}
